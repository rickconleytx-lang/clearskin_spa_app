{% extends "base.html" %}

{% block title %}
    {% if template %}Edit Email Template{% else %}Add Email Template{% endif %}
{% endblock %}

{% block content %}
<h1>
    {% if template %}
        Edit Email Template
    {% else %}
        Add Email Template
    {% endif %}
</h1>

<div class="form-buttons">
    <a href="{{ url_for('email_templates_admin') }}" class="btn">Back to Templates</a>
</div>

<form method="POST">
    <div class="form-group">
        <label for="template_name">Template Name</label>
        <input type="text"
               id="template_name"
               name="template_name"
               value="{{ template[1] if template else '' }}"
               required>
    </div>

    <div class="form-group">
        <label for="template_type">Template Type</label>
        <select id="template_type" name="template_type" required>
            <option value="">Select Type</option>
            <option value="Birthday" {% if template and template[2] == "Birthday" %}selected{% endif %}>Birthday</option>
            <option value="Gift Certificate" {% if template and template[2] == "Gift Certificate" %}selected{% endif %}>Gift Certificate</option>
            <option value="Promotion" {% if template and template[2] == "Promotion" %}selected{% endif %}>Promotion</option>
            <option value="Reminder" {% if template and template[2] == "Reminder" %}selected{% endif %}>Reminder</option>
        </select>
    </div>

    <div class="form-group">
        <label for="subject_line">Subject Line</label>
        <input type="text"
               id="subject_line"
               name="subject_line"
               value="{{ template[3] if template else '' }}"
               required>
    </div>

    <div class="form-group">
        <label for="body_text">Body Text</label>
        <textarea id="body_text"
                  name="body_text"
                  rows="14"
                  required>{{ template[4] if template else '' }}</textarea>
    </div>

    <div class="form-group">
        <label>
            <input type="checkbox"
                   name="is_active"
                   {% if template and template[5] %}checked{% endif %}>
            Active Template
        </label>
    </div>

    <div class="form-buttons">
        <button type="submit" class="btn">
            {% if template %}Save Changes{% else %}Add Template{% endif %}
        </button>
        <a href="{{ url_for('email_templates_admin') }}" class="btn">Cancel</a>
    </div>
</form>

<div style="margin-top: 30px;">
    <h3>Available Placeholders</h3>
<p style="color: red;">For All:</p>  


<div class="placeholder-grid">


    <!-- Moves the button 20px right and 10px down -->

    <code>{first_name}</code>
    <button type="button"
            class="btn btn-small"
            style="margin-left: 80px;"
            onclick="copyPlaceholder('{first_name}')">
        Copy
    </button>

    <br>

    <code>{spa_name}</code>
    <button type="button"
            class="btn btn-small"
            style="margin-left: 96px;"
            onclick="copyPlaceholder('{spa_name}')">
        Copy
    </button>

    <br>

<p style="color: red;">Birthdays:</p>

    <code>{certificate_number}</code>
cç˚˚˚
    <button type="button"
            class="btn btn-small"
            style="margin-left: 20px;"
            onclick="copyPlaceholder('{certificate_number}')">
        Copy 
    </button>
    
    <br>

<p style="color: red;">Gift Certificates:</p>    

    <code>{certificate_number}</code>
    <button type="button"
            class="btn btn-small"
            style="margin-left: 20px;"
            onclick="copyPlaceholder('{certificate_number}')">
        Copy
    </button>

    <br>
    <code>{original_value}</code>
    <button type="button"
            class="btn btn-small"
            style="margin-left: 50px;"
            onclick="copyPlaceholder('{original_value}')">
        Copy
    </button>

    <br>
    <code>{remaining_balance}</code>
    <button type="button"
            class="btn btn-small"
            style="margin-left: 25px;"
            onclick="copyPlaceholder('{remaining_balance}')">
        Copy 
    </button>

    <br>
    <code>{expires_date}</code>
    <button type="button"
            class="btn btn-small"
            style="margin-left: 65px;"
            onclick="copyPlaceholder('{expires_date}')">
        Copy 
    </button>

    <br>
    <code>{recipient_name}</code>
    <button type="button"
            class="btn btn-small"
            style="margin-left: 50px;"
            onclick="copyPlaceholder('{recipient_name}')">
        Copy 
    </button>

</div>



  
</div>




<script>
function copyPlaceholder(text) {
    navigator.clipboard.writeText(text).then(function() {
        alert(text + " copied");
    });
}
</script>


{% endblock %}
