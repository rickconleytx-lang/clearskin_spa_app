{% extends "base.html" %}

{% block title %}Income{% endblock %}

{% block content %}
<div class="section-page">
    <div class="section-header">
        <h1>Income</h1>
        <p class="section-subtitle">Manage visit income, general income, and income reporting.</p>
    </div>

    <div class="section-card-grid">
        <a class="section-card" href="{{ url_for('add_general_income') }}">
            <h3>Add General Income</h3>
            <p>Record income not tied to a client visit or appointment.</p>
        </a>

        <a class="section-card" href="{{ url_for('income_report') }}">
            <h3>Income Report</h3>
            <p>View income totals, breakdowns, and detailed transaction history.</p>
        </a>

        <a class="section-card" href="{{ url_for('gift_certificates_home') }}">
            <h3>Gift Certificates</h3>
            <p>Add New, View All and Delete a Gift Certificate.</p>
        </a>

    </div>

    <div class="money-summary">
    <div class="summary-card">
        <h3>Total Income</h3>
        <p>${{ "%.2f"|format(total_income) }}</p>
    </div>

    <div class="summary-card">
        <h3>Total Expenses</h3>
        <p>${{ "%.2f"|format(total_expenses) }}</p>
    </div>

    <div class="summary-card">
    <h3>Difference</h3>
    <p style="color: {% if net_total >= 0 %}green{% else %}red{% endif %};">
        ${{ "%.2f"|format(net_total) }}
    </p>
</div>

</div>



{% endblock %}



